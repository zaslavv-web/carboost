APP_NAME="Career Track API"
APP_ENV=production
APP_KEY=base64:PASTE_REAL_APP_KEY_HERE
APP_CIPHER=aes-256-cbc
APP_DEBUG=false
APP_URL=https://growth-peak.pro
APP_TIMEZONE=UTC
APP_LOCALE=ru

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=careertrack
DB_USERNAME=careertrack
DB_PASSWORD=PASTE_REAL_DB_PASSWORD_HERE

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=predis

SANCTUM_STATEFUL_DOMAINS=growth-peak.pro,www.growth-peak.pro,localhost:8080
SESSION_DOMAIN=.growth-peak.pro

GOOGLE_CLIENT_ID=PASTE_GOOGLE_WEB_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=PASTE_GOOGLE_WEB_CLIENT_SECRET_HERE
GOOGLE_REDIRECT_URI=https://growth-peak.pro/api/auth/google/callback

# --- Mail / SMTP ---
# Иерархия источников:
#   1) Активная запись в БД (email_settings, через админку суперадмина)
#   2) config/service-infra.php (дефолты Яндекса) — берёт пароль из SMTP_PASSWORD ниже
#   3) Legacy MAIL_* — необязательный третий уровень fallback
SMTP_PASSWORD=PASTE_YANDEX_APP_PASSWORD_HERE

MAIL_MAILER=smtp
MAIL_HOST=PASTE_SMTP_HOST_HERE
MAIL_PORT=587
MAIL_USERNAME=PASTE_SMTP_USERNAME_HERE
MAIL_PASSWORD=PASTE_SMTP_PASSWORD_HERE
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@growth-peak.pro
MAIL_FROM_NAME="Пик Роста"


FRONTEND_URL=https://growth-peak.pro
APP_FRONTEND_URL=https://growth-peak.pro

AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=PASTE_AI_KEY_HERE
AI_MODEL=gpt-4o-mini

FILESYSTEM_DISK=local