# ============================================================
# ВНИМАНИЕ
# ============================================================
# Это готовый production .env для growth-peak.pro.
# На сервере скопируйте его как `.env` в каталог backend-laravel/:
#     cp .env.production .env
#     php artisan key:generate          # сгенерирует APP_KEY
#     php artisan config:clear && php artisan config:cache
#     php artisan migrate --force
#     php artisan queue:restart
#
# !!! После заливки на сервер ОБЯЗАТЕЛЬНО смените эти секреты
#     (Google client_secret, SMTP-пароль, REVERB-ключи, DB_PASSWORD),
#     т.к. они уже попали в чат/историю.
# ============================================================

APP_NAME="Пик Роста"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.growth-peak.pro
APP_TIMEZONE=Europe/Moscow
APP_LOCALE=ru

LOG_CHANNEL=stack
LOG_LEVEL=info

# --- Database (Postgres, куда восстановлен дамп Supabase) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=careertrack
DB_USERNAME=careertrack
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# --- Cache / Queue / Session ---
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=predis

# --- Sanctum (SPA tokens) ---
SANCTUM_STATEFUL_DOMAINS=growth-peak.pro,www.growth-peak.pro,app.growth-peak.pro
SESSION_DOMAIN=.growth-peak.pro

# ============================================================
# Google OAuth (Socialite)
# ============================================================
# ВАЖНО: в Google Cloud Console у этого OAuth Client ID должны быть
# добавлены Authorized redirect URIs:
#     https://api.growth-peak.pro/api/auth/google/callback
# И Authorized JavaScript origins:
#     https://growth-peak.pro
#     https://api.growth-peak.pro
GOOGLE_CLIENT_ID=82821983974-p9i8bcablgclmk5ql253i9oia2pfie03.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=https://api.growth-peak.pro/api/auth/google/callback

# --- Reverb (WebSockets), при необходимости ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=careertrack
REVERB_APP_KEY=CHANGE_ME_REVERB_KEY
REVERB_APP_SECRET=CHANGE_ME_REVERB_SECRET
REVERB_HOST="0.0.0.0"
REVERB_PORT=8080
REVERB_SCHEME=https
REVERB_SERVER_HOST="0.0.0.0"
REVERB_SERVER_PORT=8080

# --- AI Gateway (Gemini через OpenAI-совместимый эндпоинт) ---
AI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
AI_API_KEY=${GEMINI_API_KEY}
AI_MODEL=gemini-2.5-flash

# --- Файловое хранилище: локальный диск на сервере ---
FILESYSTEM_DISK=local

# ============================================================
# SMTP — ТЕСТОВЫЕ НАСТРОЙКИ (поменяйте на боевые)
# ============================================================
# Вариант по умолчанию: Yandex 360 для домена growth-peak.pro.
# Нужно:
#   1) Создать ящик noreply@growth-peak.pro в Yandex 360
#   2) Включить "Пароли приложений" и сгенерировать пароль
#   3) Подставить его в MAIL_PASSWORD ниже
# Если используете Resend/Mailgun/Gmail — замените блок целиком
# (примеры в комментариях ниже).
MAIL_MAILER=smtp
MAIL_HOST=smtp.yandex.ru
MAIL_PORT=465
MAIL_USERNAME=noreply@growth-peak.pro
MAIL_PASSWORD=CHANGE_ME_YANDEX_APP_PASSWORD
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@growth-peak.pro"
MAIL_FROM_NAME="Пик Роста"

# --- Resend (рекомендуемый вариант, раскомментируйте при необходимости) ---
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_xxxxxxxxxxxxxxxx
# MAIL_ENCRYPTION=ssl
# MAIL_FROM_ADDRESS="noreply@growth-peak.pro"
# MAIL_FROM_NAME="Пик Роста"

# --- Mail.ru для бизнеса (альтернатива) ---
# MAIL_HOST=smtp.mail.ru
# MAIL_PORT=465
# MAIL_ENCRYPTION=ssl

# --- Gmail / Google Workspace (альтернатива) ---
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls

# --- Frontend URL (для редиректов после OAuth и password reset) ---
FRONTEND_URL=https://growth-peak.pro
APP_FRONTEND_URL=https://growth-peak.pro
