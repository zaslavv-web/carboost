# Шаблон env для Laravel-стека песочницы.
# Скопируйте в backend-laravel/.env.sandstorm и заполните секреты.

APP_NAME="Career Track Sandstorm"
APP_ENV=sandstorm
APP_KEY=
APP_DEBUG=true
APP_URL=https://growth-peak.pro/sandstorm

# --- БД ---
# Отдельный Postgres, изолированный от прода.
DB_CONNECTION=pgsql
DB_HOST=ct-sand-postgres
DB_PORT=5432
DB_DATABASE=careertrack_sand
DB_USERNAME=careertrack
DB_PASSWORD=changeme

# --- Redis ---
REDIS_HOST=ct-sand-redis
REDIS_PORT=6379

# --- SMTP ---
# В песочнице безопаснее писать в лог, чтобы случайные тестовые письма
# не уходили живым пользователям. При необходимости — переключите на smtp.
MAIL_MAILER=log
SMTP_PASSWORD=

# --- Google OAuth ---
# Используйте отдельные OAuth-credentials с redirect_uri,
# указывающим на /sandstorm/api/auth/google/callback.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI gateway ---
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini
AI_API_KEY=

# --- Frontend URL для писем и redirect'ов ---
FRONTEND_URL=https://growth-peak.pro/sandstorm
