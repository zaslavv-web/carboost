APP_NAME="Career Track API"
APP_ENV=production
APP_KEY=
APP_CIPHER=aes-256-cbc
APP_DEBUG=false
APP_URL=https://api.example.ru
APP_TIMEZONE=UTC
APP_LOCALE=ru

LOG_CHANNEL=stack
LOG_LEVEL=info

# --- Database (тот же Postgres, куда восстанавливается дамп legacy) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=careertrack
DB_USERNAME=careertrack
DB_PASSWORD=change-me

# --- Cache / Queue / Session (Redis) ---
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=predis

# --- Sanctum (SPA tokens) ---
# Домены фронта, которым разрешено получать CSRF / использовать токены
SANCTUM_STATEFUL_DOMAINS=app.example.ru,localhost:8080
SESSION_DOMAIN=.example.ru

# --- Google OAuth (Socialite) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.example.ru/api/auth/google/callback

# --- Reverb (WebSockets) ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=careertrack
REVERB_APP_KEY=change-me
REVERB_APP_SECRET=change-me
REVERB_HOST="0.0.0.0"
REVERB_PORT=8080
REVERB_SCHEME=https
REVERB_SERVER_HOST="0.0.0.0"
REVERB_SERVER_PORT=8080

# --- AI Gateway (OpenAI-совместимый: OpenAI / OpenRouter / Azure / vLLM) ---
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# --- File Storage ---
FILESYSTEM_DISK=local
# Для S3-совместимого (Selectel Object Storage):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ru-1
# AWS_BUCKET=careertrack
# AWS_ENDPOINT=https://s3.storage.selcloud.ru

# --- Mail (для password reset, нотификаций) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.ru"
MAIL_FROM_NAME="${APP_NAME}"

# Получатель уведомлений с публичных форм лендинга (демо, тарифы).
SALES_NOTIFICATION_EMAIL=growthpeak@yandex.ru

# --- Frontend URL (для редиректов после OAuth, password reset) ---
FRONTEND_URL=https://app.example.ru
