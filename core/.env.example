# core (Laravel API). Boевые значения — только в /etc/growthpeak/core.env на сервере.
APP_NAME="Growth Peak"
APP_ENV=production
APP_KEY=
APP_CIPHER=aes-256-cbc
APP_DEBUG=false
APP_URL=https://api.growth-peak.pro
APP_TIMEZONE=Europe/Moscow
APP_LOCALE=ru

LOG_CHANNEL=stack
LOG_LEVEL=info

# --- Database (PostgreSQL 14+) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=growthpeak
DB_USERNAME=growthpeak
DB_PASSWORD=

# --- Cache / Queue / Session ---
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=predis

# --- Sanctum ---
SANCTUM_STATEFUL_DOMAINS=growth-peak.pro,www.growth-peak.pro
SESSION_DOMAIN=.growth-peak.pro

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.growth-peak.pro/api/auth/google/callback

# --- Frontend URL (для редиректов и писем) ---
FRONTEND_URL=https://growth-peak.pro

# Настройки конкретных сервисов — в services/<name>/.env.example.
# На проде разложены по /etc/growthpeak/<service>.env и подключаются EnvironmentFile=.
