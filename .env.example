# ============================================================
# Frontend env (Vite) — injected at build time
# ============================================================
# Phase 13: фронт ходит только на Laravel-бэкенд.
# По-умолчанию относительный /api (проксируется nginx в Laravel).
VITE_LARAVEL_API_URL="/api"

# Реалтайм через Laravel Reverb (опционально)
VITE_REVERB_KEY=""
VITE_REVERB_HOST=""
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# ============================================================
# Laravel backend (.env в backend-laravel/)
# ============================================================
# AI gateway (любой OpenAI-совместимый endpoint):
#   - https://api.openai.com/v1/chat/completions          (OpenAI)
#   - https://openrouter.ai/api/v1/chat/completions       (OpenRouter)
#   - http://vllm:8000/v1/chat/completions                (self-hosted vLLM)
AI_API_URL="https://api.openai.com/v1/chat/completions"
AI_API_KEY="sk-..."
AI_MODEL="gpt-4o-mini"
