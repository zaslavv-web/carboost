# ============================================================
# Frontend env (Vite) — injected at build time
# ============================================================
# URL вашего self-hosted Supabase (Kong gateway), напр. https://api.example.com
VITE_SUPABASE_URL="https://api.example.com"
# Anon (publishable) ключ из self-hosted Supabase
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOi..."
VITE_SUPABASE_PROJECT_ID="self-hosted"

# ============================================================
# Edge Functions / backend secrets (set in supabase/.env или secrets)
# ============================================================
# AI gateway (любой OpenAI-совместимый endpoint):
#   - https://ai.gateway.lovable.dev/v1/chat/completions  (Lovable)
#   - https://api.openai.com/v1/chat/completions          (OpenAI)
#   - https://openrouter.ai/api/v1/chat/completions       (OpenRouter)
#   - http://vllm:8000/v1/chat/completions                (self-hosted vLLM)
AI_API_URL="https://api.openai.com/v1/chat/completions"
AI_API_KEY="sk-..."
AI_MODEL="gpt-4o-mini"
