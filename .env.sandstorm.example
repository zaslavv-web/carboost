# Шаблон фронтовых переменных песочницы.
# Используется при сборке ct-sand-web в docker-compose.sandstorm.yml.

VITE_LARAVEL_API_URL=/sandstorm/api
VITE_BASE_PATH=/sandstorm/
VITE_APP_ENV=sandstorm

# Reverb (websockets) — отдельный канал, если нужен.
VITE_REVERB_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
